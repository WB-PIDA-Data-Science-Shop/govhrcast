##### playing around with the retirement module


contract_dt  <- data.table::copy(bra_hrmis_contract)
personnel_dt <- data.table::copy(bra_hrmis_personnel)


#### simulate at the level of the entire public sector

policy_params <- list(
  group_cols   = NULL,
  policy_table = NULL,
  defaults = list(
    eligibility_type = "age_only",
    pension_type     = "db",
    min_age          = 60,
    accrual_rate     = 0.02,
    ref_wage_col     = "gross_salary_lcu",
    max_years        = 35,
    replacement_cap  = 0.80
  )
)

results <- simulate_retirement(
  contract_dt   = contract_dt,
  personnel_dt  = personnel_dt,
  policy_params = policy_params,
  ref_date      = as.Date("2014-01-01")
)

results$summary


#### simulate at the department level

policy_table <- 
  unique(contract_dt[, c("occupation_isconame", "paygrade")]) |>
  mutate(min_age = sample(seq(50, 65, 5), replace = TRUE))

policy_dt <- 
  unique(contract_dt[, c("occupation_isconame", "paygrade")])[,
  .(occupation_isconame, 
    paygrade, 
    min_age = sample(seq(50, 65, 5), replace = TRUE))][]

policy_params <- list(group_cols = c("occupation_isconame", "paygrade"),
                      policy_table = policy_dt,
                      defaults = list(
                        eligibility_type = "age_only",
                        pension_type     = "db",
                        min_age          = 60,
                        accrual_rate     = 0.02,
                        ref_wage_col     = "gross_salary_lcu",
                        max_years        = 35,
                        replacement_cap  = 0.80
                      ))

results <- simulate_retirement(contract_dt = contract_dt,
                               personnel_dt = personnel_dt,
                               policy_params = policy_params,
                               ref_date = as.Date("2014-01-01"))